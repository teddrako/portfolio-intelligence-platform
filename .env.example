# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
# Local dev:    http://localhost:3000
# Production:   https://yourdomain.com  (set this in Vercel env vars)
# Must match the Google OAuth "Authorised redirect URI" base:
#   https://yourdomain.com/api/auth/callback/google
BETTER_AUTH_URL=http://localhost:3000

# App public URL (used by the browser-side auth client)
# Local dev:   http://localhost:3000
# Production:  https://yourdomain.com  (set this in Vercel env vars)
NEXT_PUBLIC_APP_URL=http://localhost:3000

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_SECRET=""
AUTH_URL=""

# Upstash Redis (caching, rate limiting, job dedup)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Gemini Developer API (AI report generation)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# PostHog (analytics & event tracking)
# Get a key at https://app.posthog.com

# Server-side (posthog-node) — used in API routes and auth hooks
POSTHOG_KEY=phc_your-key-here
# Optional — defaults to https://us.i.posthog.com
# POSTHOG_HOST=https://us.i.posthog.com

# Client-side (posthog-js) — must be NEXT_PUBLIC_ prefixed for browser
# Use the same project key as above
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key-here
# Optional — defaults to https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# DEV ONLY: set to seed user ID to bypass Google OAuth in local development
# Run `pnpm db:seed` first, then add this to your .env
# DEV_USER_ID=user_demo_01

# ─── Market Data Provider ─────────────────────────────────────────────────────
# Leave unset (or set to "mock") to use built-in mock data.
# MARKET_DATA_PROVIDER=mock
#
# For Yahoo Finance (free, no API key — recommended for dev):
#   MARKET_DATA_PROVIDER=yahoo
#   (uses yahoo-finance2; real-time quotes + price history, unofficial API)
#
# Seed historical price data into the DB (used by risk analytics):
#   bun apps/web/scripts/seed-market-data.ts
#
# For Polygon.io (https://polygon.io):
#   MARKET_DATA_PROVIDER=polygon
#   POLYGON_API_KEY=your-polygon-api-key
# For Alpaca Markets (https://alpaca.markets):
#   MARKET_DATA_PROVIDER=alpaca
#   ALPACA_API_KEY=your-alpaca-key
#   ALPACA_API_SECRET=your-alpaca-secret

# ─── News Provider ────────────────────────────────────────────────────────────
# Leave unset (or set to "mock") to use built-in 30-article dataset.
# NEWS_PROVIDER=mock
# For Finnhub (real company news + LLM relevance scoring):
#   NEWS_PROVIDER=finnhub
#   FINNHUB_API_KEY=your-free-key-from-finnhub.io
# For Alpaca News API: NEWS_PROVIDER=alpaca  (shares ALPACA_API_KEY above)
# For Polygon.io:      NEWS_PROVIDER=polygon (shares POLYGON_API_KEY above)
# For Benzinga:        NEWS_PROVIDER=benzinga  +  BENZINGA_API_KEY=...

# ─── Calendar Provider ───────────────────────────────────────────────────────
# Leave unset (or set to "mock") to use built-in 2026 Q2 calendar.
# CALENDAR_PROVIDER=mock
#
# For Finnhub (free tier — earnings calendar + economic events, recommended):
#   CALENDAR_PROVIDER=finnhub
#   FINNHUB_API_KEY=your-free-key-from-finnhub.io   ← same key as NEWS_PROVIDER
#   Free tier covers: earnings dates, EPS/revenue estimates, economic releases.
#   Economic calendar may return [] on the free plan; earnings always work.
#
# For Polygon.io:      CALENDAR_PROVIDER=polygon (shares POLYGON_API_KEY above)
# For Alpha Vantage:   CALENDAR_PROVIDER=alphavantage  +  ALPHAVANTAGE_KEY=...

# ─── Ingestion trigger secret ─────────────────────────────────────────────────
# Protects POST /api/ingest/[type]. Leave unset in dev (open access).
# INGEST_SECRET=a-secure-random-string
#
# Vercel Cron (Pillar 4 — daily AI notes):
# vercel.json schedules POST /api/ingest/daily-close at 21:30 UTC Mon–Fri
# (4:30 PM ET standard time). Vercel sets CRON_SECRET automatically; set
# INGEST_SECRET to the same value in your Vercel project env vars so the
# existing Bearer-token auth check accepts the cron request.
# Manual trigger (dev):
#   curl -X POST http://localhost:3000/api/ingest/daily-close
# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address shown to recipients.
# For local dev: leave unset — defaults to onboarding@resend.dev (no DNS setup).
# For production: set to a verified sender on your Resend domain, e.g.:
#   Portfolio Intelligence <noreply@yourdomain.com>
# EMAIL_FROM=Portfolio Intelligence <noreply@yourdomain.com>

# ─── Pillar 5: DCF Valuation (Financial Modeling Prep) ───────────────────────
# Free tier: 250 API calls/day. Data is cached in DB so daily quota is shared
# across all valuations. Get a key at https://financialmodelingprep.com/developer/docs
# Covers: income statement, cash flow, balance sheet (annual + quarterly)
# Without this key the /valuation page still loads but shows "FMP key missing"
# FMP_API_KEY=your-fmp-api-key-here
