# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_SECRET=""
AUTH_URL=""

# Upstash Redis (caching, rate limiting, job dedup)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Gemini Developer API (AI report generation)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# DEV ONLY: set to seed user ID to bypass Google OAuth in local development
# Run `pnpm db:seed` first, then add this to your .env
# DEV_USER_ID=user_demo_01

# ─── Market Data Provider ─────────────────────────────────────────────────────
# Leave unset (or set to "mock") to use built-in mock data.
# MARKET_DATA_PROVIDER=mock
# For Polygon.io (https://polygon.io):
# MARKET_DATA_PROVIDER=polygon
# POLYGON_API_KEY=your-polygon-api-key
# For Alpaca Markets (https://alpaca.markets):
# MARKET_DATA_PROVIDER=alpaca
# ALPACA_API_KEY=your-alpaca-key
# ALPACA_API_SECRET=your-alpaca-secret

# ─── News Provider ────────────────────────────────────────────────────────────
# Leave unset (or set to "mock") to use built-in 30-article dataset.
# NEWS_PROVIDER=mock
# For Alpaca News API: NEWS_PROVIDER=alpaca  (shares ALPACA_API_KEY above)
# For Polygon.io:      NEWS_PROVIDER=polygon (shares POLYGON_API_KEY above)
# For Benzinga:        NEWS_PROVIDER=benzinga  +  BENZINGA_API_KEY=...

# ─── Calendar Provider ───────────────────────────────────────────────────────
# Leave unset (or set to "mock") to use built-in 2026 Q2 calendar.
# CALENDAR_PROVIDER=mock
# For Polygon.io:      CALENDAR_PROVIDER=polygon (shares POLYGON_API_KEY above)
# For Alpha Vantage:   CALENDAR_PROVIDER=alphavantage  +  ALPHAVANTAGE_KEY=...

# ─── Ingestion trigger secret ─────────────────────────────────────────────────
# Protects POST /api/ingest/[type]. Leave unset in dev (open access).
# INGEST_SECRET=a-secure-random-string